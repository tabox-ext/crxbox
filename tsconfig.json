{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "declaration": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "chrome"],
    "outDir": "dist"
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "tests", "fixtures"]
}
